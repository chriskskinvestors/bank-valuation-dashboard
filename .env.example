# IBKR TWS/Gateway connection
IBKR_HOST=127.0.0.1
IBKR_PORT=7497
IBKR_CLIENT_ID=1

# SEC EDGAR requires contact info in User-Agent
SEC_USER_AGENT=BankValuationDashboard yourname@company.com

# How often to refresh live prices (seconds)
PRICE_REFRESH_SECONDS=5

# How long to cache FDIC/SEC data before re-fetching (hours)
FUNDAMENTAL_CACHE_TTL_HOURS=24
